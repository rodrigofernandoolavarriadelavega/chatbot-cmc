{
  "$schema": "https://json.schemastore.org/figma-tokens",
  "$source": "Manual de Normas Gráficas CMC (oficial)",
  "brand": {
    "name": "Centro Médico Carampangue",
    "tagline": "CARAMPANGUE · CENTRO MÉDICO",
    "url": "centromedicocarampangue.cl",
    "url_corto": "agentecmc.cl",
    "contact": {
      "phone": "(44) 296 5226",
      "whatsapp": "+56 9 4588 6628",
      "emergency": "SAMU 131",
      "direccion": "Carampangue · Región del Biobío · Chile"
    }
  },
  "color": {
    "turquesa":    { "value": "#4FBECE", "rgb": "79, 190, 206", "cmyk": "64, 0, 21, 0", "uso": "Acento principal · franjas decorativas · turquesa del isotipo" },
    "turquesa-lt": { "value": "#e6f6f9", "uso": "Fondo callouts info suave" },
    "azul":        { "value": "#1172AB", "rgb": "17, 114, 171", "cmyk": "86, 48, 12, 1", "uso": "Azul corporativo · texto del logotipo · titulares H2" },
    "azul-lt":     { "value": "#e3eef6", "uso": "Fondo callouts info" },
    "navy":        { "value": "#1A3F75", "uso": "Azul navy · cruz exterior del isotipo · cuerpo de títulos" },
    "navy-dk":     { "value": "#0f2a52", "uso": "Navy oscuro · gradientes de portada" },
    "rojo":        { "value": "#c0392b", "uso": "SAMU · emergencias · ALERTA. Solo donde sea necesario por urgencia visual." },
    "rojo-lt":     { "value": "#fbe9e7", "uso": "Fondo callout danger" },
    "amarillo":    { "value": "#d4a017", "uso": "Warn · advertencias menores" },
    "amarillo-lt": { "value": "#fff8e1", "uso": "Fondo callout warn" },
    "verde":       { "value": "#2e7d57", "uso": "Success · GES · información positiva" },
    "verde-lt":    { "value": "#e8f3ee", "uso": "Fondo callout success" },
    "ink":         { "value": "#1A2A3A", "uso": "Cuerpo de texto" },
    "ink-soft":    { "value": "#4a5868", "uso": "Texto secundario · subtítulos" },
    "line":        { "value": "#d9e1ea", "uso": "Bordes y divisores" },
    "paper":       { "value": "#ffffff", "uso": "Fondo de página estándar" },
    "paper-alt":   { "value": "#f4f7fa", "uso": "Fondo de disclaimer y bloques secundarios" }
  },
  "gradient": {
    "cover-azul":     { "value": "linear-gradient(160deg, #1172AB 0%, #1A3F75 100%)", "uso": "Portada principal (default)" },
    "cover-navy":     { "value": "linear-gradient(160deg, #1A3F75 0%, #0f2a52 100%)", "uso": "Documentos serios / clínicos" },
    "cover-turquesa": { "value": "linear-gradient(160deg, #4FBECE 0%, #1172AB 100%)", "uso": "Documentos educativos / wellness" },
    "cover-red":      { "value": "linear-gradient(160deg, #c0392b 0%, #7a1f18 100%)", "uso": "Solo emergencias y SAMU" },
    "cover-green":    { "value": "linear-gradient(160deg, #2e7d57 0%, #1f5a3d 100%)", "uso": "Documentos asociados a GES y bienestar" }
  },
  "decoracion": {
    "franja-top": {
      "value": "Barra horizontal 4mm. Izquierda 10% turquesa #4FBECE, resto 90% azul #1172AB.",
      "ejemplo": "linear-gradient(to right, #4FBECE 0% 10%, #1172AB 10% 100%)",
      "uso": "Borde superior de TODAS las páginas internas (no la portada)."
    },
    "franja-bottom": {
      "value": "Idéntica a la franja-top pero en el borde inferior.",
      "uso": "Borde inferior de TODAS las páginas internas."
    }
  },
  "typography": {
    "$source": "Manual CMC indica Montserrat Bold como tipografía oficial única.",
    "font-primary":  { "value": "Montserrat", "weights": [300, 400, 500, 600, 700, 800], "fallback": "'Helvetica Neue', Arial, sans-serif" },
    "h1-cover":      { "value": { "font": "Montserrat", "size": "32pt", "weight": 700, "uppercase": true, "letter-spacing": "-0.5px", "line-height": 1.05 } },
    "h2":            { "value": { "font": "Montserrat", "size": "16pt", "weight": 700, "color": "azul", "uppercase": true, "border-bottom": "2px solid turquesa" } },
    "h3":            { "value": { "font": "Montserrat", "size": "12pt", "weight": 600, "color": "navy" } },
    "h4":            { "value": { "font": "Montserrat", "size": "10pt", "weight": 700, "uppercase": true, "letter-spacing": "0.12em", "color": "azul" } },
    "body":          { "value": { "font": "Montserrat", "size": "10.5pt", "weight": 400, "line-height": 1.55, "color": "ink" } },
    "kicker":        { "value": { "font": "Montserrat", "size": "8.5pt", "weight": 700, "uppercase": true, "letter-spacing": "0.22em", "color": "turquesa" } },
    "big-number":    { "value": { "font": "Montserrat", "size": "26pt", "weight": 800, "color": "azul", "letter-spacing": "-1px" } },
    "samu-number":   { "value": { "font": "Montserrat", "size": "44-56pt", "weight": 800, "color": "rojo" } }
  },
  "spacing": {
    "page-padding":  { "value": "22mm 18mm 18mm" },
    "page-size":     { "value": "210mm × 297mm (A4)" },
    "franja-height": { "value": "4mm" }
  },
  "logo": {
    "isotipo": {
      "descripcion": "Cruz médica conformada por una 'C' turquesa que abraza a una cruz azul corporativa, con sombra navy.",
      "fondo_recomendado": "Blanco o fondos azul/turquesa con suficiente contraste.",
      "no_usar_sobre": "Patrones complejos · imágenes con poco contraste · colores que rompan la legibilidad."
    },
    "logotipo": {
      "texto": "CARAMPANGUE",
      "subtitulo": "CENTRO MÉDICO",
      "tipografia": "Montserrat",
      "carampangue": { "weight": 700, "tracking": "0.15em", "color": "azul" },
      "centro_medico": { "weight": 500, "tracking": "0.35em", "color": "turquesa" }
    },
    "variaciones": ["isotipo solo", "vertical", "horizontal", "negativo (sobre fondo oscuro)"]
  },
  "component": {
    "card": {
      "bg": "#ffffff",
      "border": "1px solid #d9e1ea",
      "border-top": "3px solid #4FBECE",
      "radius": "2mm",
      "padding": "4mm",
      "shadow": "0 1px 3px rgba(0,0,0,0.04)"
    },
    "callout": {
      "padding": "4mm 5mm",
      "border-left": "4px solid {variant-color}",
      "radius": "0 2mm 2mm 0",
      "variants": {
        "info":    { "bg": "azul-lt",     "accent": "azul" },
        "success": { "bg": "verde-lt",    "accent": "verde" },
        "warn":    { "bg": "amarillo-lt", "accent": "amarillo" },
        "danger":  { "bg": "rojo-lt",     "accent": "rojo" },
        "default": { "bg": "turquesa-lt", "accent": "turquesa" }
      }
    },
    "phone-box": {
      "border": "2px solid #c0392b",
      "padding": "4mm 5mm",
      "radius": "3mm",
      "bg": "#ffffff"
    },
    "chip": {
      "padding": "1mm 3mm",
      "radius": "10mm",
      "font-size": "8.5pt",
      "font-weight": 700,
      "uppercase": true
    }
  },
  "documents": {
    "00_guia_mitos_realidades":       { "cover": "cover-navy",     "icon": "📖", "category": "premium" },
    "01_checklist_preconsulta":       { "cover": "cover-azul",     "icon": "📋", "category": "formulario" },
    "02_calendario_vacunas_pni":      { "cover": "cover-turquesa", "icon": "💉", "category": "informativo" },
    "03_directorio_emergencias":      { "cover": "cover-red",      "icon": "🚨", "category": "emergencia" },
    "04_glosario_fonasa_ges":         { "cover": "cover-azul",     "icon": "🏛️", "category": "informativo" },
    "05_antecedentes_familiares":     { "cover": "cover-turquesa", "icon": "🧬", "category": "formulario" },
    "06_preparacion_examenes":        { "cover": "cover-azul",     "icon": "🔬", "category": "informativo" },
    "07_guia_prequirurgica":          { "cover": "cover-navy",     "icon": "🏥", "category": "informativo" },
    "08_calculadora_imc":             { "cover": "cover-turquesa", "icon": "⚖️", "category": "educativo" },
    "09_diario_postoperatorio":       { "cover": "cover-navy",     "icon": "📆", "category": "formulario" },
    "10_cuando_llamar_131":           { "cover": "cover-red",      "icon": "🆘", "category": "emergencia" }
  }
}
